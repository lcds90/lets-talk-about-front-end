{
    "compilerOptions": {
      "outDir": "dist",
      "target": "esnext",
      "module": "esnext",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "allowJs": true,
      "strict": true,
      "noUnusedLocals": true,
      "skipLibCheck": true,
      "jsx": "preserve",
      "baseUrl": ".",
      "paths": {
        "@components/*": ["components/*"],
      }
    },
    "include": ["env.d.ts", "components/**/*", ".vitepress/**/*", "views/**/*"]
  }